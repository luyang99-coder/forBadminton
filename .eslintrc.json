{
  "env": {
    "browser": true,
    "commonjs": true,
    "es2021": true,
    "wechat": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "wx": "readonly",
    "App": "readonly",
    "Page": "readonly",
    "Component": "readonly",
    "getApp": "readonly",
    "getCurrentPages": "readonly",
    "Behavior": "readonly",
    "__wxConfig": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none", "ignoreRestSiblings": true }],
    "no-console": "off",
    "no-undef": "error",
    "no-var": "warn",
    "prefer-const": "warn",
    "eqeqeq": ["warn", "smart"],
    "no-duplicate-case": "error",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-irregular-whitespace": "error",
    "no-redeclare": ["error", { "builtinGlobals": true }],
    "no-prototype-builtins": "off",
    "valid-typeof": "error",
    "curly": ["warn", "multi-line"],
    "no-throw-literal": "warn",
    "semi": ["warn", "never"],
    "quotes": ["warn", "single", { "avoidEscape": true }]
  },
  "ignorePatterns": [
    "node_modules/",
    "cloudfunctions/**/node_modules/",
    "miniprogram_npm/",
    "*.min.js"
  ]
}
