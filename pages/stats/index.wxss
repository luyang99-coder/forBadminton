/* pages/stats/index.wxss */
/* 统计看板独立样式 — 不导入主包主题，精简加载 */

.stats-page {
  min-height: 100vh;
  background: #EEF3EF;
  padding: 16rpx;
  color: #333;
}

.loading-hint {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #999;
  font-size: 28rpx;
}

.stats-canvas {
  width: 100%;
  margin: 16rpx 0;
  border-radius: 12rpx;
  background: #fff;
}

.stats-section {
  margin-top: 24rpx;
  padding: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
  color: #999;
  font-size: 28rpx;
  line-height: 1.6;
}
