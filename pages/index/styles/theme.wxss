/* UI theme - deduplicated & merged */


/* page */
.page {
  padding: 24rpx 24rpx 230rpx;
  background:
    linear-gradient(135deg, rgba(22, 116, 79, 0.14), transparent 34%),
    linear-gradient(315deg, rgba(242, 180, 65, 0.16), transparent 30%), #eef3ef;
  color: #1d2420;
}


/* topbar */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  box-shadow: none;
  background: #fff;
}


/* brand */
.brand-copy {
  min-width: 0;
}

.brand-mark {
  display: flex;
  flex: 0 0 76rpx;
  flex-basis: 64rpx;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  box-shadow: none;
  background: linear-gradient(135deg, #16744f, #1f9b6d 55%, #f2b441);
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}


/* typography */
.subtitle {
  display: block;
  margin-top: 8rpx;
  color: #68736d;
  font-size: 23rpx;
}

.title {
  display: block;
  color: #10251f;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}


/* components */
.pill {
  flex: 0 0 auto;
  padding: 12rpx 20rpx;
  border: 1rpx solid #a3e635;
  border-radius: 999rpx;
  box-shadow: none;
  background: rgba(216, 238, 227, 0.9);
  color: #0f5e41;
  font-size: 24rpx;
  font-weight: 700;
}


/* home-hero */
.home-hero {
  position: relative;
  display: grid;
  align-items: stretch;
  justify-content: stretch;
  gap: 18rpx;
  grid-template-columns: minmax(0, 1fr);
  min-height: 0;
  overflow: hidden;
  margin-bottom: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 10rpx;
  box-shadow: none;
  background: #fff;
  color: #17201b;
}

.home-hero > button {
  position: relative;
  z-index: 2;
}

.home-hero > view {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.home-hero button {
  position: relative;
  z-index: 1;
  display: block;
  flex: none;
  align-self: stretch;
  justify-self: stretch;
  width: 100%;
  min-width: 0;
  height: 76rpx;
  margin: 0;
  padding: 0 24rpx;
  border-color: #f0b429;
  border-radius: 8rpx;
  box-shadow: none;
  background: #16744f;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.home-hero-image {
  display: none;
}

.home-hero::after {
  display: none;
  content: "";
}

.home-search {
  height: 64rpx;
  margin-bottom: 10rpx;
  padding: 0 16rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #17201b;
  font-size: 24rpx;
  line-height: 64rpx;
}

.home-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.45;
}

.home-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.28;
  letter-spacing: 0;
}

.home-tools {
  margin-bottom: 14rpx;
}


/* section */
.compact-section {
  padding-bottom: 18rpx;
}

.section {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.86);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.section-subtitle {
  display: block;
  margin-top: 4rpx;
  color: #68736d;
  font-size: 22rpx;
}

.section-title {
  display: block;
  margin-bottom: 18rpx;
  color: #10251f;
  font-size: 30rpx;
  font-weight: 800;
}


/* flow */
.flow-card {
  display: grid;
  align-items: center;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 30rpx minmax(0, 1fr) 30rpx minmax(0, 1fr);
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.86);
}

.flow-line {
  height: 4rpx;
  background: #e2e8f0;
}

.flow-line.active {
  background: #0f766e;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 8rpx;
  min-height: 78rpx;
  padding: 10rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-color: #e5e7eb;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #94a3b8;
  font-size: 22rpx;
}

.flow-step text:first-child {
  display: flex;
  flex: 0 0 40rpx;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 7rpx;
  background: rgba(216, 238, 227, 0.9);
  color: #0f5e41;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.flow-step.active {
  border-color: #16744f;
  box-shadow: none;
  background: #16744f;
  color: #fff;
  font-weight: 700;
}

.flow-step.active text:first-child {
  border-color: #f0b429;
  box-shadow: none;
  background: #f5c14d;
  color: #10251f;
}


/* tabs */
.tab {
  display: inline-block;
  height: 64rpx;
  margin-right: 10rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #334155;
  font-size: 25rpx;
  line-height: 62rpx;
}

.tab.active {
  border-color: #16744f;
  box-shadow: none;
  background: #16744f;
  color: #fff;
}

.tabs {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}


/* preset */
.preset {
  min-width: 0;
  height: 72rpx;
  overflow: hidden;
  padding: 0;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #334155;
  font-size: 26rpx;
  line-height: 70rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preset-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(3, 1fr);
}

.preset.active {
  border-color: #16744f;
  box-shadow: none;
  background: #16744f;
  color: #fff;
}


/* segmented */
.segmented {
  display: flex;
  width: 304rpx;
  padding: 4rpx;
  border-radius: 8rpx;
  background: #eef2f7;
}

.segmented button {
  flex: 1;
  min-width: 0;
  height: 58rpx;
  overflow: hidden;
  padding: 0;
  border: 0;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #334155;
  font-size: 24rpx;
  line-height: 58rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.segmented button.active {
  border-color: #16744f;
  box-shadow: none;
  background: #16744f;
  color: #fff;
}


/* mini-controls */
.mini-controls {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 14rpx;
}

.mini-controls button {
  width: 100%;
  min-width: 0;
  height: 60rpx;
  overflow: hidden;
  margin: 0;
  padding: 0;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #334155;
  font-size: 24rpx;
  line-height: 58rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-controls button.active {
  border-color: #16744f;
  box-shadow: none;
  background: #16744f;
  color: #fff;
}

.mini-controls button.warn {
  border-color: rgba(217, 99, 79, 0.3);
  background: rgba(255, 238, 235, 0.82);
  color: #9c3b2d;
}

.mini-controls.tiny {
  gap: 6rpx;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 10rpx;
}

.mini-controls.tiny button {
  height: 48rpx;
  font-size: 22rpx;
  line-height: 46rpx;
}

.mini-controls:not(.status) {
  grid-template-columns: repeat(3, 1fr);
}


/* buttons */
.copy {
  width: 100%;
  min-width: 0;
  height: 60rpx;
  overflow: hidden;
  margin-top: 10rpx;
  padding: 0;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #0f5e41;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 58rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ghost {
  min-width: 0;
  height: 84rpx;
  overflow: hidden;
  padding: 0;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #334155;
  font-size: 24rpx;
  line-height: 82rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.link-button {
  width: 100rpx;
  min-width: 0;
  height: 52rpx;
  overflow: hidden;
  padding: 0;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #0f766e;
  font-size: 24rpx;
  line-height: 50rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.primary {
  min-width: 0;
  height: 72rpx;
  border-color: #16744f;
  border-radius: 8rpx;
  box-shadow: none;
  background: #16744f;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 72rpx;
}

.primary.small {
  flex: 0 0 132rpx;
  height: 64rpx;
  background: #16744f;
  font-size: 26rpx;
  line-height: 64rpx;
}


/* notice */
.notice {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 18rpx;
  border: 1rpx solid #fed7aa;
  border-radius: 8rpx;
  background: rgba(255, 248, 230, 0.86);
  color: #805408;
  font-size: 26rpx;
}

.notice button {
  flex: 0 0 88rpx;
  height: 52rpx;
  padding: 0;
  border-radius: 6rpx;
  background: #ffedd5;
  color: #9a3412;
  font-size: 24rpx;
  line-height: 50rpx;
}

.notice text {
  flex: 1;
}

.notice.slim {
  margin-bottom: 12rpx;
  padding: 14rpx;
}


/* misc */
.generated {
  color: #68736d;
  font-size: 24rpx;
}

.hint {
  margin-top: 14rpx;
  color: #68736d;
  font-size: 22rpx;
  line-height: 1.5;
}

.muted {
  color: #64748b;
}

.rest {
  margin-top: 10rpx;
  color: #68736d;
  font-size: 24rpx;
}

.rest-picker {
  margin-top: 18rpx;
}

.warn-text {
  color: #b45309;
}


/* forms */
.field input {
  height: 64rpx;
  padding: 0 18rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
}

.field text {
  display: block;
  margin-bottom: 8rpx;
  color: #64748b;
  font-size: 22rpx;
}

.field.full {
  margin-bottom: 18rpx;
}

.field.full input {
  width: 100%;
}

.field.full-line {
  min-width: 0;
}

.form-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, 1fr);
}

.input-row {
  display: grid;
  align-items: center;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 148rpx;
}

.input-row .primary.small {
  width: 100%;
  padding: 0;
  background: #16744f;
}

.input-row input {
  flex: 1;
  height: 64rpx;
  padding: 0 18rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
}

.name-box {
  width: 100%;
  min-height: 220rpx;
  padding: 18rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
}

.name-box.short {
  min-height: 150rpx;
}

.picker-box {
  height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
  line-height: 72rpx;
}

.picker-input {
  height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
}

.picker-row {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, 1fr);
}


/* game-card */
.finish-score {
  height: 64rpx;
  padding: 0;
  border-color: #16744f;
  border-radius: 8rpx;
  box-shadow: none;
  background: #16744f;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.game-card {
  padding: 16rpx 0;
  border-top: 1rpx solid #eef2f7;
  box-shadow: none;
}

.game-card.done {
  padding-right: 12rpx;
  padding-left: 12rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.74);
}

.game-card:first-of-type {
  padding-top: 0;
  border-top: 0;
}

.my-game {
  padding-right: 12rpx;
  padding-left: 12rpx;
  border-radius: 8rpx;
  background: #ecfeff;
}

.quick-score {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 12rpx;
}

.quick-score button {
  width: 100%;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid #99f6e4;
  border-radius: 7rpx;
  box-shadow: none;
  background: rgba(216, 238, 227, 0.72);
  color: #0f5e41;
  font-size: 23rpx;
  line-height: 54rpx;
}

.round-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  color: #0f5e41;
  font-size: 24rpx;
  font-weight: 700;
}

.round-line button {
  width: 140rpx;
  min-width: 0;
  height: 52rpx;
  overflow: hidden;
  padding: 0;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #334155;
  font-size: 22rpx;
  line-height: 50rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-board {
  display: grid;
  align-items: center;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 140rpx minmax(0, 1fr);
  margin-top: 14rpx;
}

.score-row {
  display: grid;
  gap: 10rpx;
  grid-template-columns: 1fr 1fr 116rpx;
  margin-top: 12rpx;
}

.score-row button {
  height: 62rpx;
  padding: 0;
  border-color: #16744f;
  border-radius: 8rpx;
  box-shadow: none;
  background: #16744f;
  color: #fff;
  font-size: 24rpx;
  line-height: 62rpx;
}

.score-row input {
  height: 62rpx;
  padding: 0 12rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #fff;
  color: #17201b;
  font-size: 26rpx;
}

.score-side {
  display: grid;
  align-items: center;
  gap: 8rpx;
  grid-template-columns: 52rpx minmax(0, 1fr) 52rpx;
  width: 100%;
  padding: 8rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.74);
}

.score-side button {
  width: 100%;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 6rpx;
  background: #e0f2fe;
  color: #075985;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 46rpx;
}

.score-side input {
  width: 100%;
  min-width: 0;
  height: 48rpx;
  padding: 0;
  border: 1rpx solid #dbe3ea;
  border-radius: 7rpx;
  box-shadow: none;
  background: #fff;
  color: #111827;
  font-size: 28rpx;
  text-align: center;
}

.team {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 70rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.74);
  color: #111827;
  font-size: 25rpx;
}

.team-label {
  display: inline-flex;
  flex: 0 0 40rpx;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 6rpx;
  background: #16744f;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
}

.team.right {
  justify-content: flex-end;
}

.teams {
  display: grid;
  align-items: center;
  gap: 12rpx;
  grid-template-columns: 1fr 60rpx 1fr;
}

.versus {
  color: #94a3b8;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}


/* roster */
.claim-row {
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 156rpx;
  margin-top: 12rpx;
}

.claim-row button.copy {
  margin-top: 0;
}

.gender-mini {
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.gender-mini button.female.active {
  border-color: #f472b6;
  background: #f472b6;
  color: #fff;
}

.gender-mini button.gender-choice {
  height: 58rpx;
  line-height: 56rpx;
}

.gender-mini button.male.active {
  border-color: #3b82f6;
  background: #3b82f6;
  color: #fff;
}

.gender-row {
  grid-template-columns: 1fr 1fr 1fr 72rpx;
}

.level-input {
  display: grid;
  align-items: center;
  gap: 8rpx;
  grid-template-columns: 56rpx 1fr;
}

.level-input input {
  height: 58rpx;
  padding: 0 12rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  box-shadow: none;
  background: #f8fafc;
  color: #17201b;
  font-size: 24rpx;
}

.level-input text {
  color: #64748b;
  font-size: 22rpx;
}

.level-mini {
  height: 48rpx;
  padding: 0 6rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 6rpx;
  background: #fff;
  font-size: 22rpx;
  line-height: 48rpx;
  text-align: center;
}

.roster-actions {
  display: grid;
  align-items: center;
  gap: 8rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  grid-column: 2 / 3;
  margin-top: 0;
}

.roster-actions button {
  width: 100%;
  height: 50rpx;
  box-sizing: border-box;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 8rpx;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.roster-actions.single {
  display: grid;
  gap: 10rpx;
  grid-template-columns: 1fr;
  grid-column: 2 / 3;
  margin-top: 0;
}

.roster-avatar {
  width: 60rpx;
  height: 60rpx;
  margin-left: 0;
  font-size: 26rpx;
}

.roster-avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.roster-bind-state {
  display: inline-flex;
  align-items: center;
  justify-self: end;
  max-width: 220rpx;
  height: 40rpx;
  overflow: hidden;
  box-sizing: border-box;
  padding: 0 12rpx;
  border: 1rpx solid transparent;
