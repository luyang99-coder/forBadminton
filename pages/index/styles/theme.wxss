/* ============================================================
   theme.wxss — 主题样式（重构版，仅保留 CSS 变量方案）
   使用 CSS 变量统一管理主题色（主色 #16744f / 琥珀 #f0b429）
   支持跟随系统深色模式 & 手动切换
   ============================================================ */

/* ---------- CSS Custom Properties（必须放最前面）---------- */
:root,
page {
  --color-bg: #f3f6f8;
  --color-surface: #ffffff;
  --color-surface-2: #f8fafc;
  --color-surface-3: #f1f5f9;
  --color-border: #e2e8f0;
  --color-border-light: #edf0f2;
  --color-text: #17201b;
  --color-text-secondary: #475569;
  --color-text-muted: #64748b;
  --color-primary: #16744f;
  --color-primary-dark: #0f5e41;
  --color-primary-light: #eef5f1;
  --color-accent: #f0b429;
  --color-accent-light: #fff8e1;
  --color-danger: #be123c;
  --color-danger-light: #fff1f2;
  --color-avatar: #e2e8f0;
  --color-avatar-text: #475569;
  --color-hero-bg: #12342d;
  --color-hero-text: #fff;
  --bottom-nav-bg: rgba(255, 255, 255, 0.9);
  --bottom-nav-border: #e5e7eb;
  --color-tab-bg: rgba(255, 255, 255, 0.76);
  --color-tab-text: #31423a;
  --color-input-bg: rgba(255, 255, 255, 0.9);
  --color-input-border: rgba(31, 46, 38, 0.12);
  --color-card-bg-alt: rgba(255, 255, 255, 0.74);
  --color-warn-bg: rgba(255, 238, 235, 0.82);
  --color-warn-text: #9c3b2d;
  --color-claim-bg: rgba(216, 238, 227, 0.72);
  --color-claim-border: rgba(22, 116, 79, 0.26);
  --color-claim-text: #0f5e41;
  --color-status-bg: rgba(216, 238, 227, 0.84);
}

/* 跟随系统深色模式 暂时注释以兼容编译
@media (prefers-color-scheme: dark) {
  :root,
  page {
    --color-bg: #0f0f10;
    --color-surface: #1a1a1d;
    ...同上
  }
}
*/

/* ---------- 手动切换深色模式 ---------- */
[data-theme="dark"] {
  --color-bg: #0f0f10;
  --color-surface: #1a1a1d;
  --color-surface-2: #222225;
  --color-surface-3: #2a2a2e;
  --color-border: #333338;
  --color-border-light: #2a2a2e;
  --color-text: #e5e7eb;
  --color-text-secondary: #9ca3af;
  --color-text-muted: #6b7280;
  --color-primary: #2d9f78;
  --color-primary-dark: #1a8a62;
  --color-primary-light: #1a2f26;
  --color-accent: #f5c14d;
  --color-accent-light: #2a2418;
  --color-danger: #f87171;
  --color-danger-light: #2a181a;
  --color-avatar: #333338;
  --color-avatar-text: #9ca3af;
  --color-hero-bg: #1a1a1d;
  --color-hero-text: #e5e7eb;
  --bottom-nav-bg: rgba(26, 26, 29, 0.92);
  --bottom-nav-border: #333338;
  --color-tab-bg: rgba(42, 42, 46, 0.88);
  --color-tab-text: #d1d5db;
  --color-input-bg: rgba(26, 26, 29, 0.9);
  --color-input-border: rgba(255, 255, 255, 0.12);
  --color-card-bg-alt: rgba(26, 26, 29, 0.88);
  --color-warn-bg: rgba(42, 24, 26, 0.92);
  --color-warn-text: #fca5a5;
  --color-claim-bg: rgba(26, 47, 38, 0.84);
  --color-claim-border: rgba(45, 159, 120, 0.32);
  --color-claim-text: #6ee7b7;
  --color-status-bg: rgba(26, 47, 38, 0.84);
}

/* ============================================================
   以下是所有使用 CSS 变量的样式定义（仅此一套，无重复）
   ============================================================ */

/* ---------- 页面基础 ---------- */
.page {
  background: var(--color-bg);
  color: var(--color-text);
  padding: 24rpx 24rpx 230rpx;
}

/* ---------- 顶部栏 ---------- */
.topbar {
  align-items: center;
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 8rpx;
  box-shadow: none;
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 18rpx;
  position: relative;
  overflow: hidden;
}

@media (max-width: 360rpx) {
  .topbar {
    padding: 14rpx;
    margin-bottom: 12rpx;
  }
}

.brand-row {
  align-items: center;
  display: flex;
  gap: 16rpx;
  min-width: 0;
}

.brand-mark {
  align-items: center;
  background: var(--color-primary);
  border-radius: 8rpx;
  box-shadow: none;
  color: #fff;
  display: flex;
  flex: 0 0 64rpx;
  font-size: 30rpx;
  font-weight: 800;
  height: 64rpx;
  justify-content: center;
  width: 64rpx;
}

@media (max-width: 360rpx) {
  .brand-mark {
    flex-basis: 56rpx;
    height: 56rpx;
    width: 56rpx;
    font-size: 26rpx;
  }
}

.brand-copy {
  min-width: 0;
}

.title {
  color: var(--color-text);
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}

@media (max-width: 360rpx) {
  .title {
    font-size: 30rpx;
  }
}

.subtitle,
.section-subtitle,
.activity-meta,
.generated,
.hint,
.rest {
  color: var(--color-text-muted);
}

/* ---------- Pill / 标签 ---------- */
.pill,
.signup-mode,
.roster-status {
  background: var(--color-primary-light);
  border: 1rpx solid rgba(45, 159, 120, 0.3);
  border-radius: 999rpx;
  color: var(--color-primary);
  flex: 0 0 auto;
  font-size: 24rpx;
  font-weight: 700;
  padding: 12rpx 20rpx;
  box-shadow: none;
}

/* ---------- Section Head ---------- */
.section-head {
  align-items: center;
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.head-actions {
  display: flex;
  flex: 0 0 auto;
  gap: 8rpx;
  max-width: 60%;
  min-width: 0;
}

.head-actions button.copy {
  flex: 0 1 auto;
  font-size: 21rpx;
  height: 48rpx;
  line-height: 46rpx;
  margin: 0;
  min-width: 0;
  overflow: hidden;
  padding: 0 10rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: auto;
}

/* ---------- 首页Hero ---------- */
.home-hero {
  align-items: flex-start;
  background: var(--color-hero-bg);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 8rpx;
  box-shadow: none;
  color: var(--color-hero-text);
  min-height: 0;
  overflow: hidden;
  padding: 30rpx;
  position: relative;
}

@media (max-width: 360rpx) {
  .home-hero {
    flex-direction: column;
    padding: 18rpx;
  }
}

.home-hero::after,
.home-hero-image {
  display: none;
}

.home-hero > view,
.home-hero > button {
  position: relative;
  z-index: 2;
}

.home-title {
  color: var(--color-hero-text);
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.08;
}

.home-subtitle {
  color: rgba(255, 255, 255, 0.84);
  font-weight: 500;
}

@media (max-width: 360rpx) {
  .home-title {
    font-size: 32rpx;
  }
  .home-hero button {
    flex: 0 0 auto;
    width: 176rpx;
  }
}

.home-hero button,
.bottom-nav .launch {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: var(--color-text);
  box-shadow: none;
}

/* ---------- 卡片基础 ---------- */
.section,
.flow-card,
.profile-card,
.empty-state,
.activity-card,
.record-card,
.roster-item,
.progress-card,
.game-card.done,
.team,
.score-side,
.constraint-chip,
.roster-tools,
.signup-box {
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 8rpx;
  box-shadow: none;
}

.roster-item.open-slot {
  background: linear-gradient(135deg, var(--color-surface), var(--color-primary-light));
}

.section {
  padding: 22rpx;
}

@media (max-width: 360rpx) {
  .section {
    padding: 16rpx;
  }
}

.section-title {
  color: var(--color-text);
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

/* ---------- Flow 卡片 ---------- */
.flow-card {
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 30rpx minmax(0, 1fr) 30rpx minmax(0, 1fr);
  padding: 12rpx;
}

@media (max-width: 360rpx) {
  .flow-card {
    grid-template-columns: 1fr;
  }
  .flow-line {
    display: none;
  }
}

.flow-step {
  align-items: center;
  background: var(--color-surface-2);
  border: 1rpx solid var(--color-border);
  border-radius: 8rpx;
  gap: 8rpx;
  justify-content: flex-start;
  min-height: 76rpx;
  padding: 10rpx;
  display: flex;
}

.flow-step.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}

.flow-step text:first-child {
  background: var(--color-primary-light);
  border-radius: 7rpx;
  color: var(--color-primary);
  flex: 0 0 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  width: 40rpx;
}

.flow-step.active text:first-child {
  background: var(--color-accent);
  color: var(--color-text);
}

.flow-line {
  background: var(--color-border);
}

.flow-line.active,
.progress-fill,
.trend-fill {
  background: var(--color-primary);
}

/* ---------- Tab按钮 ---------- */
.tab,
.mini-controls button,
.link-button,
.copy,
.round-line button,
.ghost,
.status-actions button,
.activity-actions button,
.quick-score button,
.quick-row button,
.setup-inline button,
.preset,
.segmented button,
.recommend button {
  background: var(--color-tab-bg);
  border: 1rpx solid var(--color-input-border);
  border-radius: 8rpx;
  color: var(--color-tab-text);
  font-size: 24rpx;
  height: 60rpx;
  line-height: 58rpx;
  min-width: 0;
  overflow: hidden;
  padding: 0;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin: 0;
  width: 100%;
  box-shadow: none;
  box-sizing: border-box;
}

.preset {
  font-size: 26rpx;
  height: 72rpx;
  line-height: 70rpx;
}

.tab.active,
.preset.active,
.segmented button.active,
.mini-controls button.active,
.status-actions button.active,
.status-actions .inline-primary {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
}

/* 主要按钮 */
.primary,
.finish-score,
.empty-actions button,
.score-row button {
  background: var(--color-primary);
  border-color: var(--color-primary);
  color: #fff;
  border-radius: 8rpx;
  box-shadow: none;
  box-sizing: border-box;
}

.primary {
  font-size: 30rpx;
  font-weight: 700;
  height: 72rpx;
  line-height: 72rpx;
  min-width: 0;
}

.primary.small {
  flex: 0 0 132rpx;
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
}

.input-row .primary.small {
  padding: 0;
  width: 100%;
}

/* ---------- 输入框 ---------- */
.input-row input,
.field input,
.picker-box,
.picker-input,
.home-search,
.score-row input,
.score-side input,
.roster-name,
.roster-level,
.roster-claim,
.level-input input {
  background: var(--color-input-bg);
  border: 1rpx solid var(--color-input-border);
  border-radius: 8rpx;
  color: var(--color-text);
  box-shadow: none;
  box-sizing: border-box;
}

.input-row input,
.field input {
  font-size: 28rpx;
  height: 64rpx;
  padding: 0 18rpx;
}

.roster-name,
.roster-level,
.roster-claim {
  font-size: 24rpx;
  height: 58rpx;
  min-width: 0;
  padding: 0 12rpx;
  width: 100%;
}

/* ---------- 链接色 / 副本按钮 ---------- */
.copy,
.link-inline,
.load-more,
.activity-status,
.quality-grid text:first-child,
.round-line {
  color: var(--color-primary);
}

.link-inline {
  background: transparent;
  font-size: 24rpx;
  height: 48rpx;
  line-height: 48rpx;
  margin-top: 8rpx;
  padding: 0;
  text-align: left;
}

/* ---------- 认领/活动按钮 ---------- */
.roster-claim,
.load-more,
.quick-score button,
.roster-tools button.copy,
.roster-link,
.roster-link.bound {
  background: var(--color-claim-bg);
  border: 1rpx solid var(--color-claim-border);
  color: var(--color-claim-text);
}

.roster-link.bound {
  border-color: rgba(22, 116, 79, 0.32);
}

.roster-link {
  font-weight: 800;
}

/* ---------- 危险按钮 ---------- */
.roster-remove,
.constraint-chip button,
.activity-actions .danger,
.mini-controls button.warn,
.status-actions button.warn {
  background: var(--color-warn-bg);
  border: 1rpx solid rgba(217, 99, 79, 0.3);
  color: var(--color-warn-text);
}

/* ---------- 状态徽章 ---------- */
.roster-status {
  background: var(--color-status-bg);
  color: var(--color-claim-text);
}

.roster-status.bench,
.roster-status.late {
  background: var(--color-accent-light);
  color: #805408;
}

.roster-status.absent {
  background: var(--color-warn-bg);
  color: var(--color-warn-text);
}

.roster-bind-state {
  background: rgba(255, 255, 255, 0.7);
  color: var(--color-text-muted);
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
  padding: 8rpx 12rpx;
}

.roster-item.status-bench {
  border-color: rgba(242, 180, 65, 0.36);
}

.roster-item.status-absent {
  opacity: 0.72;
}

.roster-status-actions {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 10rpx;
}

.roster-status-actions button {
  height: 52rpx;
  line-height: 50rpx;
}

.roster-status-actions button.bench {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: var(--color-text);
}

/* ---------- 统计网格 ---------- */
.summary-grid view,
.quality-grid view,
.review-grid view,
.stats-grid view {
  background: var(--color-surface-2);
  border: 1rpx solid var(--color-border-light);
  border-radius: 8rpx;
  box-shadow: none;
  padding: 16rpx;
}

.summary-grid text:first-child {
  color: var(--color-accent);
}

.quality-grid text:first-child {
  color: var(--color-primary);
}

.review-grid text:first-child {
  color: var(--color-text-muted);
  display: block;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.review-grid text:last-child {
  color: var(--color-text);
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
}

/* ---------- Notice ---------- */
.notice {
  background: var(--color-accent-light);
  border-color: rgba(242, 180, 65, 0.34);
  color: #805408;
  align-items: center;
  border-radius: 8rpx;
  display: flex;
  font-size: 26rpx;
  gap: 12rpx;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 18rpx;
}

.notice text {
  flex: 1;
}

.notice button {
  background: rgba(255, 238, 196, 0.9);
  border-radius: 6rpx;
  color: #805408;
  flex: 0 0 88rpx;
  font-size: 24rpx;
  height: 52rpx;
  line-height: 50rpx;
  padding: 0;
}

.notice.slim {
  margin-bottom: 12rpx;
  padding: 14rpx;
}

/* ---------- Bottom nav ---------- */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: var(--bottom-nav-bg, rgba(255,255,255,0.95));
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-top: 0.5px solid var(--bottom-nav-border, rgba(0,0,0,0.06));
  z-index: 100;
}

.bottom-nav button {
  flex: 1;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  background: transparent;
  border: none;
  border-radius: 0;
  transition: color 0.2s;
  padding: 0;
}

.bottom-nav button::after { border: none; }

.bottom-nav button.active {
  color: var(--color-primary);
  font-weight: 600;
}

.bottom-nav button.active::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 0 0 4rpx 4rpx;
}

.bottom-nav .launch {
  color: #fff;
  font-weight: 600;
}

/* ---------- Signup ---------- */
.signup-mode {
  background: var(--color-claim-bg);
  border: 1rpx solid var(--color-claim-border);
  border-radius: 999rpx;
  color: var(--color-claim-text);
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 800;
  padding: 8rpx 18rpx;
}

.signup-mode.bench,
.signup-submit.bench {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: var(--color-text);
}

.signup-box {
  background: rgba(255, 255, 255, 0.58);
  padding: 14rpx;
}

.signup-input {
  grid-template-columns: minmax(0, 1fr) 168rpx;
}

@media (max-width: 360rpx) {
  .signup-input {
    grid-template-columns: minmax(0, 1fr) 138rpx;
  }
}

.signup-submit {
  font-weight: 900;
}

.signup-hint {
  color: var(--color-text-muted);
  font-size: 22rpx;
  line-height: 1.4;
  margin-top: 12rpx;
}

/* ---------- Roster ---------- */
.roster-headline {
  align-items: center;
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.roster-list {
  display: grid;
  gap: 12rpx;
  margin-top: 14rpx;
}

.roster-item {
  padding: 12rpx;
  overflow: hidden;
}

.roster-main {
  align-items: center;
  display: grid;
  gap: 8rpx;
  grid-template-columns: minmax(0, 1fr) 220rpx 92rpx;
}

.roster-top {
  align-items: center;
  display: grid;
  gap: 8rpx;
  grid-template-columns: minmax(0, 1fr) 118rpx;
}

.roster-level-box {
  align-items: center;
  display: grid;
  gap: 6rpx;
  grid-template-columns: 28rpx minmax(0, 1fr);
  min-width: 0;
  width: 100%;
}

.roster-level-box text {
  color: var(--color-text-muted);
  font-size: 22rpx;
  text-align: center;
}

.roster-actions {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 10rpx;
}

.roster-actions.single {
  grid-template-columns: 1fr;
}

.roster-actions button {
  border-radius: 8rpx;
  font-size: 22rpx;
  height: 52rpx;
  line-height: 50rpx;
  margin: 0;
  padding: 0;
}

.roster-remove {
  font-weight: 800;
}

.roster-tools {
  align-items: center;
  padding: 10rpx;
}

.roster-tools input {
  background: var(--color-surface);
}

.roster-tools button.copy {
  font-weight: 700;
  margin-top: 0;
}

.roster-tools button.copy:last-child {
  background: var(--color-claim-bg);
  border-color: var(--color-claim-border);
  color: var(--color-claim-text);
}

.claim-row {
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 156rpx;
  margin-top: 12rpx;
}

.claim-row button.copy {
  margin-top: 0;
}

.gender-mini {
  gap: 10rpx;
}

.gender-mini button.gender-choice {
  height: 58rpx;
  line-height: 56rpx;
}

.gender-mini button.male.active {
  background: #3b82f6;
  border-color: #3b82f6;
  color: #fff;
}

.gender-mini button.female.active {
  background: #f472b6;
  border-color: #f472b6;
  color: #fff;
}

/* ---------- 活动卡片 ---------- */
.activity-card {
  box-shadow: 0 10rpx 28rpx rgba(32, 54, 42, 0.08);
}

.activity-title,
.player-name,
.profile-name,
.status-title {
  color: var(--color-text);
}

/* ---------- 团队/比赛 ---------- */
.team-label,
.avatar {
  background: linear-gradient(135deg, var(--color-primary), #1f9b6d);
}

.team-label {
  align-items: center;
  border-radius: 6rpx;
  color: #fff;
  display: inline-flex;
  flex: 0 0 40rpx;
  font-size: 22rpx;
  font-weight: 700;
  height: 40rpx;
  justify-content: center;
  width: 40rpx;
}

/* ---------- Tab顶部导航 ---------- */
.tabs {
  margin-bottom: 18rpx;
  white-space: nowrap;
  width: 100%;
}

.tab {
  display: inline-block;
  font-size: 25rpx;
  height: 64rpx;
  line-height: 62rpx;
  margin-right: 10rpx;
  padding: 0 24rpx;
  width: auto;
}

/* ---------- 分段控制器 ---------- */
.segmented {
  background: var(--color-surface-2);
  border-radius: 8rpx;
  display: flex;
  padding: 4rpx;
  width: 304rpx;
}

.segmented button {
  border: 0;
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
}

/* ---------- Score ---------- */
.score-board {
  align-items: center;
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr auto 1fr;
  margin-top: 16rpx;
}

.score-side {
  align-items: center;
  display: grid;
  gap: 8rpx;
  grid-template-columns: 52rpx minmax(0, 1fr) 52rpx;
  padding: 8rpx;
  width: 100%;
}

.score-side button {
  background: var(--color-claim-bg);
  border: 1rpx solid var(--color-claim-border);
  border-radius: 6rpx;
  color: var(--color-claim-text);
  font-size: 28rpx;
  font-weight: 700;
  height: 48rpx;
  line-height: 46rpx;
  padding: 0;
  width: 100%;
  margin: 0;
}

.score-side input {
  font-size: 28rpx;
  height: 48rpx;
  min-width: 0;
  padding: 0;
  text-align: center;
  width: 100%;
}

.score-row {
  display: grid;
  gap: 10rpx;
  grid-template-columns: 1fr 1fr 116rpx;
  margin-top: 12rpx;
}

.finish-score {
  font-size: 26rpx;
  font-weight: 700;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 32rpx;
  margin: 0;
  border-radius: 28rpx;
  background: var(--color-primary);
  color: #fff;
  white-space: nowrap;
}

.quick-score {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 12rpx;
}

.quick-score button {
  font-size: 23rpx;
  height: 56rpx;
  line-height: 54rpx;
  padding: 0;
  margin: 0;
}

/* ---------- Game card ---------- */
.game-card {
  border-top: 1rpx solid var(--color-border-light);
  padding: 16rpx 0;
}

.game-card:first-of-type {
  border-top: 0;
  padding-top: 0;
}

.round-line {
  align-items: center;
  display: flex;
  font-size: 24rpx;
  font-weight: 700;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.round-line button {
  width: 140rpx;
  margin: 0;
}

.teams {
  align-items: center;
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 60rpx 1fr;
}

.team {
  align-items: center;
  display: flex;
  font-size: 25rpx;
  gap: 10rpx;
  min-height: 70rpx;
  padding: 12rpx;
}

.team.right {
  justify-content: flex-end;
}

.versus {
  color: var(--color-text-muted);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.rest {
  font-size: 24rpx;
  margin-top: 10rpx;
}

.rest-sm {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.copy {
  font-weight: 700;
  margin-top: 10rpx;
  width: 100%;
}

/* ---------- 输入容器 ---------- */
.input-row {
  align-items: center;
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 148rpx;
}

.single-meta-row {
  align-items: center;
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 186rpx;
  margin-top: 12rpx;
}

.picker-row {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, 1fr);
}

.picker-box,
.picker-input {
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 18rpx;
}

.form-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, 1fr);
}

.activity-info-grid {
  grid-template-columns: 1fr;
}

.admin-row,
.share-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.share-actions button {
  flex: 1 1 auto;
  min-width: 120rpx;
  max-width: 100%;
  height: 56rpx;
  line-height: 54rpx;
  font-size: 22rpx;
  margin: 0;
  padding: 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.share-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.share-actions button {
  flex: 1 1 auto;
  min-width: 120rpx;
  max-width: 100%;
  height: 56rpx;
  line-height: 54rpx;
  font-size: 22rpx;
  margin: 0;
  padding: 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.status-actions {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(auto-fit, minmax(180rpx, 1fr));
}

.status-actions button {
  height: 62rpx;
  line-height: 60rpx;
  margin: 0;
}

.status-actions .inline-primary {
  font-size: 23rpx;
  font-weight: 700;
}

.home-tools {
  margin-bottom: 14rpx;
}

.home-search {
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin-bottom: 10rpx;
  padding: 0 16rpx;
}

.load-more {
  font-size: 22rpx;
  height: 56rpx;
  line-height: 54rpx;
  margin-top: 12rpx;
  padding: 0;
  width: auto;
}

.load-more.wide {
  width: 100%;
}

.actions {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 160rpx;
  margin-bottom: 20rpx;
}

.ghost {
  height: 84rpx;
  line-height: 82rpx;
}

/* ---------- 约束 ---------- */
.constraint-list {
  margin-top: 18rpx;
}

.constraint-title {
  color: var(--color-text-muted);
  display: block;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.constraint-chip {
  align-items: center;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  margin-bottom: 10rpx;
  padding: 12rpx;
}

.constraint-chip button {
  border-radius: 6rpx;
  font-size: 22rpx;
  height: 48rpx;
  line-height: 46rpx;
  padding: 0;
  width: 88rpx;
}

/* ---------- 开关行 ---------- */
.switch-row {
  border-top: 1rpx solid var(--color-border);
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.switch-row label {
  align-items: center;
  color: var(--color-text-secondary);
  display: flex;
  font-size: 26rpx;
  gap: 8rpx;
}

/* ---------- 费用管理 ---------- */
.fee-list { margin-bottom: 12rpx; }

.fee-item {
  align-items: center;
  background: var(--color-surface);
  border-radius: 12rpx;
  display: flex;
  gap: 12rpx;
  margin-bottom: 10rpx;
  padding: 16rpx 20rpx;
}

.fee-info {
  align-items: center;
  display: flex;
  flex: 1;
  gap: 12rpx;
}

.fee-name-input {
  background: var(--color-bg);
  border-radius: 8rpx;
  flex: 2;
  font-size: 26rpx;
  padding: 10rpx 14rpx;
}

.fee-amount-input {
  background: var(--color-bg);
  border-radius: 8rpx;
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  padding: 10rpx 14rpx;
  text-align: right;
}

.fee-currency { color: var(--color-text-secondary); font-size: 24rpx; }

.fee-delete {
  background: none;
  color: var(--color-warn-text);
  font-size: 28rpx;
  padding: 4rpx 8rpx;
}

.fee-summary {
  align-items: center;
  background: linear-gradient(135deg, var(--color-primary), #1f9b6d);
  border-radius: 14rpx;
  color: #fff;
  display: flex;
  font-size: 26rpx;
  font-weight: 600;
  gap: 24rpx;
  justify-content: center;
  padding: 20rpx;
}

.fee-summary .fee-hint { font-size: 22rpx; opacity: .8; }

/* 缴费状态标签 */
.fee-payment-row {
  align-items: center;
  display: flex;
  flex: 1;
  gap: 10rpx;
}

.fee-payment-row input {
  background: var(--color-bg);
  border-radius: 6rpx;
  font-size: 24rpx;
  padding: 6rpx 10rpx;
  width: 120rpx;
}

.fee-due { color: var(--color-text-secondary); font-size: 24rpx; white-space: nowrap; }

.fee-status { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 20rpx; white-space: nowrap; }

.fee-status.paid { background: rgba(22, 116, 79, .15); color: var(--color-primary); }

.fee-status.partial { background: rgba(240, 180, 41, .15); color: #b8860b; }

.fee-status.unpaid { background: rgba(200, 60, 60, .12); color: #c83c3c; }

/* ---------- EOF ---------- */

/* ---------- Mine Page ---------- */
.mine-page {
  padding-bottom: 40rpx;
}

.mine-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 24rpx;
  margin: 12rpx 20rpx 16rpx;
  background: linear-gradient(135deg, #16744F, #1a8a5a);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(22, 116, 79, 0.25);
}

.mine-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mine-hero-text {
  flex: 1;
  min-width: 0;
}

.mine-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.mine-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
}

/* Summary grid items */
.sg-item {
  text-align: center;
  padding: 20rpx 16rpx;
}

.sg-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 4rpx;
}

.sg-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* Trend cards */
.trend-cards {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.trend-card {
  background: var(--color-surface);
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
}

.tc-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.tc-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.tc-rate {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.tc-track {
  height: 8rpx;
  background: var(--color-surface-3);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.tc-fill {
  height: 100%;
  background: linear-gradient(90deg, #16744F, #2d9f78);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.tc-stat {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* Record cards */
.rc-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 6rpx;
}

.rc-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rc-date {
  font-size: 22rpx;
  color: var(--color-text-muted);
  flex-shrink: 0;
  margin-left: 16rpx;
}

.rc-meta {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.rc-summary {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

/* ============ Home V2 Styles ============ */
.home-v2 { padding-bottom: 40rpx; }

.hero-banner {
  position: relative; margin: 12rpx 20rpx; padding: 40rpx 32rpx;
  border-radius: 24rpx; overflow: hidden;
  background: linear-gradient(135deg, #16744F 0%, #1a8a5a 40%, #0d4a30 100%);
  box-shadow: 0 8rpx 32rpx rgba(22, 116, 79, 0.3);
}
.hero-bg {
  position: absolute; top: -50%; right: -20%;
  width: 300rpx; height: 300rpx; border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.hero-bg::after {
  content: ''; position: absolute; top: 50%; left: 50%;
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(255,255,255,0.05); transform: translate(-30%, -30%);
}
.hero-content { position: relative; z-index: 1; }
.hero-title { display: block; font-size: 38rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.hero-subtitle { display: block; font-size: 24rpx; color: rgba(255,255,255,0.75); }
.hero-stats {
  position: relative; z-index: 1; display: flex; margin-top: 28rpx;
  background: rgba(255,255,255,0.15); border-radius: 16rpx; padding: 16rpx 0;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}
.hero-stat-item { flex: 1; text-align: center; border-right: 1rpx solid rgba(255,255,255,0.2); }
.hero-stat-item:last-child { border-right: none; }
.hero-stat-num { display: block; font-size: 36rpx; font-weight: 700; color: #fff; }
.hero-stat-label { display: block; font-size: 20rpx; color: rgba(255,255,255,0.7); margin-top: 4rpx; }

.quick-actions {
  display: flex; gap: 16rpx; padding: 24rpx; margin: -20rpx 20rpx 16rpx;
  background: var(--card-bg, #fff); border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06); justify-content: flex-end;
}
.qa-btn {
  flex: 0 1 auto; display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  padding: 24rpx 64rpx; background: transparent; border: none; border-radius: 24rpx;
  font-size: 22rpx; line-height: 1;
}
.qa-btn::after { border: none; }
.qa-btn:active { transform: scale(0.95); opacity: 0.8; }
.qa-primary { background: linear-gradient(135deg, #16744F, #1a8a5a); }
.qa-primary:active { transform: scale(0.97); opacity: 0.9; }
.qa-primary .qa-label { color: #fff; }
.qa-icon { font-size: 36rpx; display: block; }
.qa-label { display: block; color: var(--text-color, #333); font-size: 22rpx; }

.section-header { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.section-count { font-size: 24rpx; color: #999; }
.home-search-wrap { width: 280rpx; }
.home-search-inline {
  height: 60rpx; padding: 0 28rpx; background: var(--color-surface-3, #f1f5f9);
  border-radius: 30rpx; font-size: 24rpx;
  color: var(--color-text);
  border: 1px solid transparent;
  transition: border-color 0.2s;
}

.home-search-inline:focus {
  border-color: var(--color-primary);
  background: var(--color-surface);
}

.active-cards-h { display: flex; white-space: nowrap; padding: 8rpx 0; }
.active-card-featured {
  display: inline-block; width: 560rpx; margin-right: 20rpx; padding: 24rpx;
  background: var(--card-bg, #fff); border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06); white-space: normal; transition: transform 0.2s;
}
.active-card-featured:active { transform: scale(0.97); }
.afc-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.afc-title { font-size: 30rpx; font-weight: 600; color: var(--text-color, #333); flex: 1; overflow: hidden; text-overflow: ellipsis; }
.afc-badge { font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 20rpx; white-space: nowrap; margin-left: 12rpx; }
.afc-badge.signup { background: #e8f5e9; color: #16744F; }
.afc-badge.locked { background: #fff3e0; color: #e65100; }
.afc-badge.started { background: #e3f2fd; color: #1565c0; }
.afc-body { margin-bottom: 16rpx; }
.afc-info-row { display: flex; gap: 24rpx; font-size: 24rpx; color: var(--text-secondary, #666); margin-bottom: 8rpx; }
.afc-progress { margin-top: 12rpx; }
.afc-progress-text { font-size: 22rpx; color: #999; }
.afc-progress-bar { height: 8rpx; background: #eee; border-radius: 4rpx; margin-top: 8rpx; overflow: hidden; }
.afc-progress-fill { height: 100%; background: linear-gradient(90deg, #16744F, #1a8a5a); border-radius: 4rpx; transition: width 0.3s; }
.afc-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 16rpx; border-top: 1rpx solid var(--border-color, #f0f0f0); }
.afc-updated { font-size: 22rpx; color: #bbb; }
.afc-arrow { font-size: 28rpx; color: #16744F; }

.ended-card {
  display: flex; align-items: center; padding: 20rpx 24rpx; margin-bottom: 12rpx;
  background: var(--card-bg, #fff); border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.ec-left { flex: 1; min-width: 0; }
.ec-title { display: block; font-size: 28rpx; font-weight: 500; color: var(--text-color, #333); margin-bottom: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ec-meta { display: block; font-size: 22rpx; color: #999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ec-right .ec-arrow { font-size: 32rpx; color: #ccc; padding-left: 16rpx; }

/* Dark mode */
[data-theme="dark"] .hero-banner {
  background: linear-gradient(135deg, #0d4a30 0%, #0f5e41 40%, #092e1e 100%);
}
[data-theme="dark"] .active-card-featured,
[data-theme="dark"] .ended-card,
[data-theme="dark"] .quick-actions {
  background: #1e1e1e; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}
[data-theme="dark"] .afc-title,
[data-theme="dark"] .ec-title { color: #e0e0e0; }
[data-theme="dark"] .afc-info-row,
[data-theme="dark"] .ec-meta { color: #999; }
[data-theme="dark"] .afc-footer { border-top-color: #333; }
[data-theme="dark"] .home-search-inline { background: #2a2a2a; color: #e0e0e0; }
[data-theme="dark"] .home-search-inline:focus {
  background: var(--color-surface);
  border-color: var(--color-primary);
}
[data-theme="dark"] .afc-progress-bar { background: #333; }
[data-theme="dark"] .qa-primary {
  background: linear-gradient(135deg, #1a8a62, #2d9f78);
}

/* Poster canvas — kept offscreen for Canvas 2D export */
.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: 0;
  width: 375px;
  height: 680px;
  pointer-events: none;
}

