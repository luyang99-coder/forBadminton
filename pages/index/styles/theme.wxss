  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.7;
}

.repeat-title {
  color: #111827;
  font-weight: 700;
}


/* empty */
.empty-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 18rpx;
}

.empty-actions button {
  height: 64rpx;
  padding: 0;
  border-color: #16744f;
  border-radius: 8rpx;
  box-shadow: none;
  background: #16744f;
  color: #fff;
  font-size: 25rpx;
  line-height: 64rpx;
}

.empty-state {
  padding: 34rpx 24rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.86);
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
}

.empty-state text {
  display: block;
}


/* profile */
.avatar {
  display: flex;
  flex: 0 0 92rpx;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #16744f;
  color: #2563eb;
  font-size: 32rpx;
  font-weight: 700;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.86);
}

.profile-name {
  display: block;
  color: #10251f;
  font-size: 31rpx;
  font-weight: 800;
}

.profile-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
}


/* poster */
.poster-canvas {
  position: fixed;
  top: 0;
  left: -9999rpx;
  width: 375px;
  height: 680px;
}


/* bottom-nav */
.bottom-nav {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: grid;
  align-items: center;
  grid-template-columns: repeat(3, 1fr);
  height: 124rpx;
  padding: 12rpx 28rpx 18rpx;
  border-top: 1rpx solid #e5e7eb;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.9);
}

.bottom-nav .launch {
  height: 82rpx;
  margin: 0 30rpx;
  border-color: #f0b429;
  border-radius: 999rpx;
  box-shadow: none;
  background: #f5c14d;
  color: #10251f;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 82rpx;
}

.bottom-nav button {
  height: 76rpx;
  padding: 0;
  background: transparent;
  color: #94a3b8;
  font-size: 25rpx;
  line-height: 76rpx;
}

.bottom-nav button.active {
  color: #0f5e41;
  font-weight: 700;
}

.bottom-nav.in-activity {
  grid-template-columns: repeat(2, 1fr);
}


/* quick-setup */
.quick-row {
  display: grid;
  align-items: end;
  gap: 12rpx;
  grid-template-columns: minmax(96rpx, 120rpx) repeat(2, minmax(0, 1fr));
  margin-top: 16rpx;
}

.quick-row button {
  width: 100%;
  margin: 0;
  border-color: rgba(31, 46, 38, 0.12);
  border-radius: 7rpx;
  box-shadow: none;
  background: #fff;
  color: #17201b;
}

.quick-row input {
  width: 100%;
  height: 64rpx;
  padding: 0 14rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 26rpx;
}

.setup-inline {
  display: grid;
  align-items: end;
  gap: 12rpx;
  grid-template-columns: repeat(auto-fit, minmax(180rpx, 1fr));
  margin-top: 16rpx;
}

.setup-inline button {
  width: 100%;
  margin: 0;
  border-color: rgba(31, 46, 38, 0.12);
  border-radius: 7rpx;
  box-shadow: none;
  background: #fff;
  color: #17201b;
}

.setup-inline input {
  width: 100%;
  height: 64rpx;
  padding: 0 14rpx;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 26rpx;
}

.setup-inline.schedule-targets {
  align-items: stretch;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.setup-inline.schedule-targets button {
  min-height: 76rpx;
  white-space: normal;
}


/* constraint */
.constraint-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: none;
  background: rgba(255, 255, 255, 0.74);
  font-size: 24rpx;
}

.constraint-chip button {
  width: 88rpx;
  height: 48rpx;
  padding: 0;
  border-color: rgba(217, 99, 79, 0.3);
  border-radius: 6rpx;
  background: rgba(255, 238, 235, 0.82);
  color: #9c3b2d;
  font-size: 22rpx;
  line-height: 46rpx;
}

.constraint-list {
  margin-top: 18rpx;
}

.constraint-title {
  display: block;
  margin-bottom: 10rpx;
  color: #64748b;
  font-size: 24rpx;
}


/* switch */
.switch-row {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e5e7eb;
}

.switch-row label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #334155;
  font-size: 26rpx;
}


/* actions */
.actions {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 160rpx;
  margin-bottom: 20rpx;
}


/* signup */
.signup-box {
  padding: 14rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  box-shadow: none;
  background: #fff;
}

.signup-hint {
  margin-top: 12rpx;
  color: #68736d;
  font-size: 22rpx;
  line-height: 1.4;
}

.signup-input {
  grid-template-columns: minmax(0, 1fr) 168rpx;
}

.signup-mode {
  flex: 0 0 auto;
  padding: 8rpx 18rpx;
  border: 1rpx solid rgba(22, 116, 79, 0.24);
  border-color: #cfe7d8;
  border-radius: 999rpx;
  box-shadow: none;
  background: #eef7f1;
  color: #16744f;
  font-size: 22rpx;
  font-weight: 800;
}

.signup-mode.bench {
  border-color: #f0b429;
  box-shadow: none;
  background: #f0b429;
  color: #17201b;
}

.signup-submit {
  font-weight: 900;
}

.signup-submit.bench {
  border-color: #f0b429;
  box-shadow: none;
  background: #f0b429;
  color: #17201b;
}


/* load-more */
.load-more {
  height: 56rpx;
  margin-top: 12rpx;
  padding: 0;
  border: 1rpx solid #99f6e4;
  border-radius: 8rpx;
  background: rgba(216, 238, 227, 0.72);
  color: #0f5e41;
  font-size: 22rpx;
  line-height: 54rpx;
}

.load-more.wide {
  width: 100%;
}


/* misc-layout */
.head-actions {
  display: flex;
  gap: 8rpx;
}

.mine-badge {
  right: -6rpx;
  width: 28rpx;
  height: 28rpx;
  font-size: 18rpx;
  line-height: 28rpx;
}


/* other */
.action-panel .status-actions {
  grid-template-columns: repeat(auto-fit, minmax(150rpx, 1fr));
}

.link-inline {
  height: 48rpx;
  margin-top: 8rpx;
  padding: 0;
  background: transparent;
  color: #0f5e41;
  font-size: 24rpx;
  line-height: 48rpx;
  text-align: left;
}

.single-meta-row {
  display: grid;
  align-items: center;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 186rpx;
  margin-top: 12rpx;
}

.single-meta-row .gender-mini {
  margin-top: 0;
}

@media (max-width: 360px) {
  .action-panel .status-actions {
    grid-template-columns: 1fr;
  }
  .activity-actions {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-column: 1 / -1;
  }
  .activity-card {
    grid-template-columns: minmax(0, 1fr) 84rpx;
  }
  .activity-status {
    text-align: left;
  }
  .brand-mark {
    flex-basis: 64rpx;
    width: 64rpx;
    height: 64rpx;
  }
  .finish-score {
    width: 100%;
  }
  .flow-card {
    grid-template-columns: 1fr;
  }
  .flow-line {
    display: none;
  }
  .handicap-grid {
    grid-template-columns: 1fr;
  }
  .home-hero {
    flex-direction: column;
    align-items: flex-start;
    min-height: 320rpx;
  }
  .home-hero button {
    flex: 0 0 auto;
    width: 176rpx;
  }
  .input-row {
    grid-template-columns: minmax(0, 1fr) 132rpx;
  }
  .quick-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .quick-row.roster-tools {
    grid-template-columns: 96rpx repeat(2, minmax(0, 1fr));
  }
  .quick-score {
    grid-template-columns: 1fr;
  }
  .review-grid {
    grid-template-columns: 1fr;
  }
  .roster-actions {
    grid-template-columns: 1fr;
    grid-column: 1 / -1;
  }
  .roster-actions.single {
    grid-column: 1 / -1;
  }
  .roster-avatar {
    width: 54rpx;
    height: 54rpx;
  }
  .roster-bind-state {
    justify-self: start;
  }
  .roster-gender {
    grid-column: 1 / -1;
  }
  .roster-headline {
    grid-template-columns: minmax(0, 1fr) auto;
  }
  .roster-item {
    grid-template-columns: 62rpx minmax(0, 1fr);
    padding: 12rpx;
  }
  .roster-item.open-slot {
    grid-template-columns: 62rpx minmax(0, 1fr);
    padding: 12rpx;
  }
  .roster-item.status-absent {
    grid-template-columns: 62rpx minmax(0, 1fr);
    padding: 12rpx;
  }
  .roster-item.status-bench {
    grid-template-columns: 62rpx minmax(0, 1fr);
    padding: 12rpx;
  }
  .roster-main {
    grid-template-columns: minmax(0, 1fr);
  }
  .roster-top {
    grid-template-columns: minmax(0, 1fr) auto;
  }
  .score-board {
    grid-template-columns: 1fr;
  }
  .score-side {
    grid-template-columns: 44rpx minmax(0, 1fr) 44rpx;
  }
  .score-side button {
    font-size: 24rpx;
  }
  .setup-inline {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .setup-inline.schedule-targets {
    grid-template-columns: 1fr;
  }
  .share-actions {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .signup-input {
    grid-template-columns: minmax(0, 1fr) 138rpx;
  }
  .single-meta-row {
    grid-template-columns: minmax(0, 1fr) 150rpx;
  }
  .stats-grid {
    grid-template-columns: 1fr;
  }
  .title {
    font-size: 34rpx;
  }
}
