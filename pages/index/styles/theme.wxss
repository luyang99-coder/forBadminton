  display: flex;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.roster-name.readonly {
  font-size: 30rpx;
  font-weight: 500;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 18rpx;
}

/* Compact roster layout for mobile signup screens. */
.roster-list {
  gap: 12rpx;
}

.roster-item,
.roster-item.open-slot,
.roster-item.status-bench,
.roster-item.status-absent {
  gap: 10rpx;
  grid-template-columns: 70rpx minmax(0, 1fr);
  padding: 14rpx 16rpx;
}

.roster-avatar {
  font-size: 26rpx;
  height: 60rpx;
  margin-left: 0;
  width: 60rpx;
}

.mine-badge {
  font-size: 18rpx;
  height: 28rpx;
  line-height: 28rpx;
  right: -6rpx;
  width: 28rpx;
}

.roster-main {
  display: grid;
  gap: 8rpx;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
}

.roster-headline,
.roster-top,
.roster-subline {
  grid-column: 1 / -1;
}

.roster-headline {
  gap: 8rpx;
}

.roster-slot {
  font-size: 34rpx;
  line-height: 42rpx;
}

.roster-status,
.roster-bind-state {
  font-size: 22rpx;
  height: 40rpx;
  line-height: 38rpx;
  padding: 0 12rpx;
}

.roster-top {
  gap: 8rpx;
  grid-template-columns: minmax(0, 1fr) 112rpx;
}

.roster-name,
.roster-claim,
.roster-level,
.roster-level-box {
  height: 58rpx;
}

.roster-name,
.roster-claim,
.roster-level {
  font-size: 26rpx;
  line-height: 56rpx;
  padding: 0 14rpx;
}

.roster-level-box {
  grid-template-columns: 38rpx minmax(0, 1fr);
  padding: 0 8rpx;
}

.roster-level-box text {
  font-size: 21rpx;
}

.roster-level-box .roster-level {
  height: 56rpx;
  line-height: 56rpx;
}

.roster-subline {
  font-size: 22rpx;
  margin-top: -2rpx;
}

.roster-gender {
  grid-column: 1 / 2;
}

.roster-actions,
.roster-actions.single {
  grid-column: 2 / 3;
}

.roster-gender .gender-choice,
.roster-actions button {
  height: 50rpx;
  line-height: 48rpx;
}

.roster-actions {
  gap: 8rpx;
}

@media (max-width: 360px) {
  .roster-item,
  .roster-item.open-slot,
  .roster-item.status-bench,
  .roster-item.status-absent {
    grid-template-columns: 62rpx minmax(0, 1fr);
    padding: 12rpx;
  }

  .roster-avatar {
    height: 54rpx;
    width: 54rpx;
  }

  .roster-headline,
  .roster-top {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .roster-main {
    grid-template-columns: minmax(0, 1fr);
  }

  .roster-gender,
  .roster-actions,
  .roster-actions.single {
    grid-column: 1 / -1;
  }
}

.roster-level.readonly {
  font-size: 28rpx;
  font-weight: 600;
  height: 60rpx;
  justify-content: center;
  line-height: 60rpx;
  padding: 0;
  text-align: center;
}
