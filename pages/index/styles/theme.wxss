.bottom-nav button.active {
  color: #16744f;
}

.topbar {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.title {
  color: #0f172a;
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.subtitle {
  color: #64748b;
  display: block;
  font-size: 23rpx;
  margin-top: 8rpx;
}

.pill {
  background: #d9f99d;
  border: 1rpx solid #a3e635;
  border-radius: 999rpx;
  color: #365314;
  flex: 0 0 auto;
  font-size: 24rpx;
  font-weight: 700;
  padding: 12rpx 20rpx;
}

.tabs {
  margin-bottom: 18rpx;
  white-space: nowrap;
  width: 100%;
}

.tab {
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  color: #334155;
  display: inline-block;
  font-size: 25rpx;
  height: 64rpx;
  line-height: 62rpx;
  margin-right: 10rpx;
  padding: 0 24rpx;
}

.tab.active {
  background: #0f766e;
  border-color: #0f766e;
  color: #fff;
}

.section {
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.03);
}

.compact-section {
  padding-bottom: 18rpx;
}

.section-head {
  align-items: center;
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #111827;
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.section-subtitle {
  color: #64748b;
  display: block;
  font-size: 22rpx;
  margin-top: 4rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.head-actions {
  display: flex;
  gap: 8rpx;
}

.home-tools {
  margin-bottom: 14rpx;
}

.home-search {
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin-bottom: 10rpx;
  padding: 0 16rpx;
}

.load-more {
  background: #ecfeff;
  border: 1rpx solid #99f6e4;
  border-radius: 8rpx;
  color: #0f766e;
  font-size: 22rpx;
  height: 56rpx;
  line-height: 54rpx;
  margin-top: 12rpx;
  padding: 0;
}

.load-more.wide {
  width: 100%;
}

.preset-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(3, 1fr);
}

.preset,
.segmented button,
.recommend button,
.ghost,
.mini-controls button,
.link-button,
.copy,
.round-line button {
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  color: #334155;
  font-size: 24rpx;
  height: 60rpx;
  line-height: 58rpx;
  min-width: 0;
  overflow: hidden;
  padding: 0;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-controls button,
.status-actions button,
.share-actions button,
.activity-actions button,
.quick-score button,
.quick-row button,
.setup-inline button,
.score-side button {
  margin: 0;
  width: 100%;
}

.preset {
  font-size: 26rpx;
  height: 72rpx;
  line-height: 70rpx;
}

.preset.active,
.segmented button.active,
.mini-controls button.active {
  background: #0f766e;
  border-color: #0f766e;
  color: #fff;
}

.mini-controls button.warn {
  background: #dc2626;
  border-color: #dc2626;
}

.segmented {
  background: #eef2f7;
  border-radius: 8rpx;
  display: flex;
  padding: 4rpx;
  width: 304rpx;
}

.segmented button {
  border: 0;
  flex: 1;
  height: 58rpx;
  line-height: 58rpx;
}

.name-box {
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  color: #111827;
  font-size: 28rpx;
  min-height: 220rpx;
  padding: 18rpx;
  width: 100%;
}

.name-box.short {
  min-height: 150rpx;
}

.input-row {
  align-items: center;
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 148rpx;
}

.single-meta-row {
  align-items: center;
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 186rpx;
  margin-top: 12rpx;
}

.roster-list {
  display: grid;
  gap: 12rpx;
  margin-top: 14rpx;
}

.roster-item {
  background: #fff;
  border: 1rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 12rpx;
  overflow: hidden;
}

.roster-main {
  align-items: center;
  display: grid;
  gap: 8rpx;
  grid-template-columns: minmax(0, 1fr) 220rpx 92rpx;
}

.roster-top {
  align-items: center;
  display: grid;
  gap: 8rpx;
  grid-template-columns: minmax(0, 1fr) 118rpx;
}

.roster-name,
.roster-level,
.roster-claim {
  background: #fff;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  font-size: 24rpx;
  height: 58rpx;
  min-width: 0;
  padding: 0 12rpx;
  width: 100%;
}

.roster-claim {
  background: #ecfdf5;
  border-color: #99f6e4;
  color: #0f766e;
  font-weight: 700;
  line-height: 56rpx;
  margin: 0;
}

.roster-item.open-slot {
  background: #f8fffd;
}

.roster-item button[disabled],
.roster-item input[disabled] {
  opacity: 0.72;
}

.roster-level-box {
  align-items: center;
  display: grid;
  gap: 6rpx;
  grid-template-columns: 28rpx minmax(0, 1fr);
  min-width: 0;
  width: 100%;
}

.roster-level-box text {
  color: #64748b;
  font-size: 22rpx;
  text-align: center;
}

.roster-actions {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 10rpx;
