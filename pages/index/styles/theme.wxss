  }

  .single-meta-row {
    grid-template-columns: minmax(0, 1fr) 150rpx;
  }

  .activity-card {
    grid-template-columns: minmax(0, 1fr) 84rpx;
  }

  .activity-status {
    text-align: left;
  }

  .activity-actions {
    grid-column: 1 / -1;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .action-panel .status-actions,
  .stats-grid,
  .review-grid {
    grid-template-columns: 1fr;
  }

  .share-actions {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .quick-row,
  .setup-inline {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .setup-inline.schedule-targets {
    grid-template-columns: 1fr;
  }

  .quick-row.roster-tools {
    grid-template-columns: 96rpx repeat(2, minmax(0, 1fr));
  }

  .roster-main {
    grid-template-columns: 1fr;
  }

  .roster-actions {
    grid-template-columns: 1fr;
  }

  .handicap-grid {
    grid-template-columns: 1fr;
  }

  .score-board {
    grid-template-columns: 1fr;
  }

  .finish-score {
    width: 100%;
