/* UI refresh inspired by the reference badminton assistant */
.page {
  background:
    linear-gradient(135deg, rgba(22, 116, 79, 0.14), transparent 34%),
    linear-gradient(315deg, rgba(242, 180, 65, 0.16), transparent 30%),
    #eef3ef;
  color: #1d2420;
  padding: 24rpx 24rpx 230rpx;
}

.topbar {
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.brand-row {
  align-items: center;
  display: flex;
  gap: 16rpx;
  min-width: 0;
}

.brand-mark {
  align-items: center;
  background: linear-gradient(135deg, #16744f, #1f9b6d 55%, #f2b441);
  border-radius: 50%;
  box-shadow: 0 12rpx 28rpx rgba(22, 116, 79, 0.24);
  color: #fff;
  display: flex;
  flex: 0 0 76rpx;
  font-size: 34rpx;
  font-weight: 800;
  height: 76rpx;
  justify-content: center;
  width: 76rpx;
}

.brand-copy {
  min-width: 0;
}

.title {
  color: #10251f;
  font-size: 40rpx;
  font-weight: 800;
}

.subtitle,
.section-subtitle,
.activity-meta,
.generated,
.hint,
.rest {
  color: #68736d;
}

.pill {
  background: rgba(216, 238, 227, 0.9);
  border-color: rgba(22, 116, 79, 0.26);
  color: #0f5e41;
  box-shadow: 0 10rpx 24rpx rgba(32, 54, 42, 0.08);
}

.home-hero {
  background: #12342d;
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 8rpx;
  box-shadow: 0 22rpx 65rpx rgba(16, 37, 31, 0.23);
  color: #fff;
  min-height: 276rpx;
  overflow: hidden;
  padding: 30rpx;
  position: relative;
}

.home-hero::after {
  background:
    linear-gradient(90deg, rgba(10, 25, 21, 0.82) 0%, rgba(10, 25, 21, 0.44) 58%, rgba(10, 25, 21, 0.24) 100%);
  bottom: 0;
  content: "";
  left: 0;
  position: absolute;
  right: 0;
  top: 0;
  z-index: 1;
}

.home-hero-image {
  bottom: 0;
  height: 100%;
  left: 0;
  opacity: 0.92;
  position: absolute;
  right: 0;
  top: 0;
  width: 100%;
  z-index: 0;
}

.home-hero > view,
.home-hero > button {
  position: relative;
  z-index: 2;
}

.home-title {
  color: #fff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.08;
}

.home-subtitle {
  color: rgba(255, 255, 255, 0.84);
  font-weight: 700;
}

.home-hero button,
.bottom-nav .launch {
  background: #f5c14d;
  color: #10251f;
  box-shadow: 0 12rpx 28rpx rgba(242, 180, 65, 0.22);
}

.section,
.flow-card,
.profile-card,
.empty-state {
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 55rpx rgba(32, 54, 42, 0.12);
}

.section {
  padding: 22rpx;
}

.section-title {
  color: #10251f;
  font-weight: 850;
}

.flow-card {
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 30rpx minmax(0, 1fr) 30rpx minmax(0, 1fr);
  padding: 14rpx;
}

.flow-step {
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
  gap: 8rpx;
  justify-content: flex-start;
  min-height: 76rpx;
  padding: 10rpx;
}

.flow-step.active {
  background: linear-gradient(135deg, #16744f, #23856a);
  border-color: rgba(22, 116, 79, 0.52);
  color: #fff;
}

.flow-step text:first-child {
  background: rgba(216, 238, 227, 0.9);
  border-radius: 7rpx;
  color: #0f5e41;
  flex: 0 0 40rpx;
  height: 40rpx;
  line-height: 40rpx;
}

.flow-step.active text:first-child {
  background: #f5c14d;
  color: #10251f;
}

.flow-line {
  background: rgba(31, 46, 38, 0.12);
}

.flow-line.active,
.progress-fill,
.trend-fill {
  background: #16744f;
}

.tab,
.mini-controls button,
.link-button,
.copy,
.round-line button,
.ghost,
.status-actions button,
.activity-actions button,
.quick-score button,
.quick-row button,
.setup-inline button {
  background: rgba(255, 255, 255, 0.76);
  border-color: rgba(31, 46, 38, 0.12);
  border-radius: 7rpx;
  color: #31423a;
}

.tab.active,
.preset.active,
.segmented button.active,
.mini-controls button.active,
.status-actions button.active,
.status-actions .inline-primary,
.primary,
.finish-score,
.empty-actions button,
.score-row button {
  background: #16744f;
  border-color: #16744f;
  color: #fff;
}

.primary.small,
.input-row .primary.small {
  background: #16744f;
}

.copy,
.link-inline,
.load-more {
  color: #0f5e41;
}

.input-row input,
.field input,
.picker-box,
.picker-input,
.home-search,
.score-row input,
.score-side input,
.roster-name,
.roster-level,
.roster-claim {
  background: rgba(255, 255, 255, 0.9);
  border-color: rgba(31, 46, 38, 0.12);
  border-radius: 7rpx;
  color: #1d2420;
}

.roster-item,
.activity-card,
.record-card,
.game-card.done,
.progress-card,
.quality-grid view,
.summary-grid view,
.review-grid view,
.stats-grid view,
.team,
.score-side,
.constraint-chip,
.roster-tools {
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(31, 46, 38, 0.12);
  border-radius: 8rpx;
}

.roster-item.open-slot {
  background: linear-gradient(135deg, #ffffff, #d8eee3);
}

.roster-claim,
.load-more,
.quick-score button,
.roster-tools button.copy {
  background: rgba(216, 238, 227, 0.72);
  border-color: rgba(22, 116, 79, 0.26);
  color: #0f5e41;
}

.roster-remove,
.constraint-chip button,
.activity-actions .danger,
.mini-controls button.warn,
.status-actions button.warn {
  background: rgba(255, 238, 235, 0.82);
  border-color: rgba(217, 99, 79, 0.3);
  color: #9c3b2d;
}

.roster-link {
  background: rgba(216, 238, 227, 0.72);
  border-color: rgba(22, 116, 79, 0.22);
  color: #0f5e41;
}

.roster-link.bound {
  background: #d8eee3;
  border-color: rgba(22, 116, 79, 0.32);
}

.activity-title,
.player-name,
.profile-name,
.status-title {
  color: #10251f;
}

.activity-card {
  box-shadow: 0 10rpx 28rpx rgba(32, 54, 42, 0.08);
}

.activity-status {
  color: #0f5e41;
  font-weight: 800;
}

.team-label,
.avatar {
  background: linear-gradient(135deg, #16744f, #1f9b6d);
}

.summary-grid text:first-child {
  color: #b77916;
}

.quality-grid text:first-child,
.round-line {
  color: #16744f;
}

.notice {
  background: rgba(255, 248, 230, 0.86);
  border-color: rgba(242, 180, 65, 0.34);
  color: #805408;
}

.notice button {
  background: rgba(255, 238, 196, 0.9);
  color: #805408;
}

.bottom-nav {
  background: rgba(255, 255, 255, 0.9);
  border-top-color: rgba(31, 46, 38, 0.12);
  box-shadow: 0 -12rpx 36rpx rgba(32, 54, 42, 0.12);
}

.bottom-nav button.active {
  color: #0f5e41;
}

.signup-mode {
  background: rgba(216, 238, 227, 0.86);
  border: 1rpx solid rgba(22, 116, 79, 0.24);
  border-radius: 999rpx;
  color: #0f5e41;
  flex: 0 0 auto;
  font-size: 22rpx;
  font-weight: 800;
  padding: 8rpx 18rpx;
}

.signup-mode.bench,
.signup-submit.bench {
  background: #f5c14d;
  border-color: #f5c14d;
  color: #10251f;
}

.signup-box {
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(31, 46, 38, 0.1);
  border-radius: 8rpx;
  padding: 14rpx;
}

.signup-input {
  grid-template-columns: minmax(0, 1fr) 168rpx;
}

.signup-submit {
  font-weight: 900;
}

.signup-hint {
  color: #68736d;
  font-size: 22rpx;
  line-height: 1.4;
  margin-top: 12rpx;
}

.roster-headline {
  align-items: center;
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.roster-status,
.roster-bind-state {
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1;
  padding: 8rpx 12rpx;
}

.roster-status {
  background: rgba(216, 238, 227, 0.84);
  color: #0f5e41;
}

.roster-status.bench,
.roster-status.late {
  background: rgba(255, 248, 230, 0.92);
  color: #805408;
}

.roster-status.absent {
  background: rgba(255, 238, 235, 0.92);
  color: #9c3b2d;
}

.roster-bind-state {
  background: rgba(255, 255, 255, 0.7);
  color: #68736d;
}

.roster-item.status-bench {
  border-color: rgba(242, 180, 65, 0.36);
}

.roster-item.status-absent {
  opacity: 0.72;
}

.roster-status-actions {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 10rpx;
}

.roster-status-actions button {
  height: 52rpx;
  line-height: 50rpx;
}

.roster-status-actions button.bench {
  background: #f5c14d;
  border-color: #f5c14d;
  color: #10251f;
}

.roster-actions {
  align-items: center;
}

.roster-remove {
  font-weight: 800;
}

.roster-link {
  font-weight: 800;
}

@media (max-width: 360px) {
  .brand-mark {
    flex-basis: 64rpx;
    height: 64rpx;
    width: 64rpx;
  }

  .title {
    font-size: 34rpx;
  }

  .home-hero {
    align-items: flex-start;
    flex-direction: column;
    min-height: 320rpx;
  }

  .home-hero button {
    flex: 0 0 auto;
    width: 176rpx;
  }

  .flow-card {
    grid-template-columns: 1fr;
  }

  .flow-line {
    display: none;
  }

  .signup-input {
    grid-template-columns: minmax(0, 1fr) 138rpx;
  }
}

