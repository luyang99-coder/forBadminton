/* ============================================================
   base.wxss — 基础布局 + 全部机型适配
   断点：≤360px（小屏）/ 360-374px（标准窄）/ 375-414px（主流）/ ≥414px（大屏）
   所有 grid / flex 均有 overflow 保护
   ============================================================ */

/* ---------- 小屏覆盖层通配 ---------- */
@media (max-width: 360rpx) {
  .page { padding: 16rpx 12rpx 140rpx; }
}
@media (min-width: 414rpx) {
  .page { padding: 28rpx 32rpx 160rpx; }
}
@media (min-width: 450rpx) {
  .page { padding: 32rpx 40rpx 180rpx; }
}

/* ---------- 页面根 ---------- */
.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 150rpx;
  background: #f3f6f8;
}

/* ---------- 顶部栏 ---------- */
.topbar {
  position: relative;
  overflow: hidden;
}

/* ---------- 报名 Tab ---------- */
.roster-tabs {
  align-items: center;
  background: #fff;
  border-bottom: 1rpx solid #edf0f2;
  border-top: 1rpx solid #edf0f2;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 16rpx -22rpx 18rpx;
}
@media (max-width: 360rpx) {
  .roster-tabs { margin: 12rpx -12rpx 14rpx; }
}

.roster-tabs view {
  color: #111827;
  font-size: 30rpx;
  font-weight: 500;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
@media (max-width: 360rpx) {
  .roster-tabs view { font-size: 26rpx; height: 68rpx; line-height: 68rpx; }
}

.roster-tabs .active {
  color: #d97706;
  font-weight: 800;
}

/* ---------- 名单列表 ---------- */
.roster-list {
  background: #fff;
  border-top: 1rpx solid #f1f5f9;
  gap: 0;
}

.roster-item,
.roster-item.open-slot,
.roster-item.status-bench,
.roster-item.status-absent {
  align-items: start;
  border: 0;
  border-bottom: 1rpx solid #f1f5f9;
  border-radius: 0;
  display: grid;
  gap: 18rpx;
  grid-template-columns: 84rpx minmax(0, 1fr);
  padding: 22rpx 0;
}
@media (max-width: 360rpx) {
  .roster-item,
  .roster-item.open-slot,
  .roster-item.status-bench,
  .roster-item.status-absent {
    grid-template-columns: 72rpx minmax(0, 1fr);
    gap: 14rpx;
    padding: 18rpx 0;
  }
}

/* ---------- 头像 ---------- */
.roster-avatar {
  align-items: center;
  background: #e2e8f0;
  border-radius: 50%;
  color: #475569;
  display: flex;
  font-size: 30rpx;
  font-weight: 700;
  height: 72rpx;
  justify-content: center;
  margin-left: 10rpx;
  position: relative;
  width: 72rpx;
}
@media (max-width: 360rpx) {
  .roster-avatar { height: 62rpx; width: 62rpx; margin-left: 6rpx; font-size: 26rpx; }
}
@media (min-width: 414rpx) {
  .roster-avatar { height: 80rpx; width: 80rpx; font-size: 34rpx; }
}

.roster-avatar.empty {
  background: #fffaf0;
  border: 2rpx dashed #d9a62e;
  color: #d9a62e;
}
.roster-avatar.mine {
  background: #eef5f1;
  color: #2f6f58;
}
.mine-badge {
  background: #6aa7e8;
  border-radius: 50%;
  bottom: -2rpx;
  color: #fff;
  font-size: 20rpx;
  height: 32rpx;
  line-height: 32rpx;
  position: absolute;
  right: -8rpx;
  text-align: center;
  width: 32rpx;
}

/* ---------- 名单主体 ---------- */
.roster-main {
  min-width: 0;
  padding-right: 10rpx;
}

.roster-headline {
  align-items: center;
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
@media (max-width: 360rpx) {
  .roster-headline { flex-wrap: wrap; gap: 6rpx; }
}

.roster-title-row {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  min-width: 0;
}

.roster-slot {
  color: #111827;
  flex: 0 0 auto;
  font-size: 32rpx;
  font-weight: 700;
}
@media (max-width: 360rpx) {
  .roster-slot { font-size: 28rpx; }
}

/* ---------- 状态标签 ---------- */
.roster-status {
  background: transparent;
  border: 0;
  color: #64748b;
  font-size: 22rpx;
  height: auto;
  line-height: 1.2;
  padding: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}
.roster-status.bench,
.roster-status.late,
.roster-status.absent {
  display: inline-flex;
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 800;
}
.roster-status.bench { background: rgba(242, 180, 65, 0.18); color: #8a5a00; }
.roster-status.late { background: rgba(242, 180, 65, 0.18); color: #8a5a00; }
.roster-status.absent { background: rgba(217, 99, 79, 0.14); color: #9c3b2d; }

/* ---------- 性别符号 ---------- */
.roster-gender-symbol {
  font-size: 26rpx;
  font-weight: 800;
  flex: 0 0 auto;
}
.roster-gender-symbol.male { color: #4f9ddf; }
.roster-gender-symbol.female { color: #d94f8c; }
@media (max-width: 360rpx) {
  .roster-gender-symbol { font-size: 22rpx; }
}

/* ---------- 绑定状态 ---------- */
.roster-bind-state {
  background: transparent;
  border: 0;
  color: #9ca3af;
  font-size: 24rpx;
  height: auto;
  line-height: 1.2;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0;
}
.roster-bind-state.self { color: #111827; }
@media (max-width: 360rpx) {
  .roster-bind-state {
    justify-self: start;
    max-width: 120rpx;
  }
}

/* ---------- 名单输入行 ---------- */
.roster-top {
  grid-template-columns: minmax(0, 1fr) 112rpx;
}
@media (max-width: 360rpx) {
  .roster-top { grid-template-columns: 1fr; gap: 6rpx; }
}

.roster-name,
.roster-claim {
  background: transparent;
  border: 0;
  color: #111827;
  font-size: 34rpx;
  font-weight: 500;
  height: 50rpx;
  line-height: 50rpx;
  padding: 0;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
@media (max-width: 360rpx) {
  .roster-name,
  .roster-claim { font-size: 30rpx; }
}
.roster-claim { color: #d97706; text-align: left; }

.roster-level-box {
  background: transparent;
  border: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  height: 50rpx;
  padding: 0;
}
.roster-level-box text {
  color: #9ca3af;
  font-size: 22rpx;
  flex: 0 0 auto;
}
.roster-level-box .roster-level {
  color: #111827;
  font-size: 28rpx;
  height: 50rpx;
  line-height: 50rpx;
  min-width: 0;
}

.roster-subline {
  color: #a3a3a3;
  font-size: 24rpx;
  line-height: 1.35;
  margin-top: 2rpx;
  overflow-wrap: break-word;
  word-break: break-all;
}

/* ---------- 性别按钮小控件 ---------- */
.roster-gender {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}
.roster-gender .gender-choice {
  height: 48rpx;
  line-height: 46rpx;
  flex: 0 0 92rpx;
}
@media (max-width: 360rpx) {
  .roster-gender .gender-choice { flex: 1 1 72rpx; }
}

/* ---------- 名单操作按钮 ---------- */
.roster-actions,
.roster-actions.single {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}
.roster-actions > button,
.roster-actions.single > button {
  flex: 1 1 calc(50% - 5rpx);
  min-width: 0;
  height: 52rpx;
  line-height: 50rpx;
}
.roster-actions.single > button {
  flex: 1 1 100%;
}

/* ---------- 小屏覆盖层 1 ---------- */
@media (max-width: 360rpx) {
  .roster-actions button { flex-basis: 100%; }
}

/* ---------- 名单大小工具 ---------- */
.roster-size-tools,
.roster-tools.compact.roster-size-tools {
  align-items: stretch;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 136rpx;
  margin: 16rpx 0 12rpx;
  padding: 12rpx;
}
@media (max-width: 360rpx) {
  .roster-size-tools,
  .roster-tools.compact.roster-size-tools {
    grid-template-columns: 1fr;
  }
}
@media (min-width: 414rpx) {
  .roster-size-tools,
  .roster-tools.compact.roster-size-tools {
    grid-template-columns: minmax(0, 1fr) 160rpx;
  }
}

.roster-size-field {
  align-items: center;
  background: #fff;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  box-sizing: border-box;
  display: grid;
  gap: 10rpx;
  grid-template-columns: 132rpx minmax(0, 1fr);
  height: 64rpx;
  padding: 0 14rpx;
}
@media (max-width: 360rpx) {
  .roster-size-field { grid-template-columns: 124rpx minmax(0, 1fr); }
}

.roster-size-field text {
  color: #475569;
  font-size: 24rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.roster-size-field input {
  background: transparent;
  border: 0;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  text-align: right;
}

.roster-size-tools .bench-add {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 8rpx;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 800;
  height: 64rpx;
  line-height: 62rpx;
  margin: 0;
  padding: 0;
}

/* ---------- 抽屉只读 ---------- */
.drawer-input-row.readonly {
  grid-template-columns: minmax(0, 1fr);
}
.drawer-input-row.readonly input { color: #64748b; }

/* ---------- 玩家行操作 ---------- */
.drawer-row .player-row-actions,
.drawer-row .player-row-actions.single {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 4rpx;
}
.drawer-row .player-row-actions button {
  box-sizing: border-box;
  flex: 1 1 180rpx;
  min-width: 0;
}
@media (max-width: 360rpx) {
  .drawer-row .player-row-actions button { flex-basis: 100%; }
}

/* ---------- 紧凑名单工具 ---------- */
.roster-tools.compact {
  align-items: center;
  display: grid;
  gap: 12rpx;
  grid-template-columns: minmax(0, 1fr) 150rpx 190rpx;
  margin: 18rpx 0 10rpx;
}
@media (max-width: 360rpx) {
  .roster-tools.compact { grid-template-columns: 1fr; }
}

/* ---------- 玩家列表（新） ---------- */
.player-list {
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  gap: 0;
  margin-top: 8rpx;
}

.player-row,
.player-row.open-slot,
.player-row.status-bench,
.player-row.status-absent {
  align-items: start;
  border: 0;
  border-bottom: 1rpx solid #f0f0f0;
  border-radius: 0;
  gap: 22rpx;
  grid-template-columns: 78rpx minmax(0, 1fr);
  padding: 24rpx 8rpx;
}
@media (max-width: 360rpx) {
  .player-row,
  .player-row.open-slot,
  .player-row.status-bench,
  .player-row.status-absent {
    grid-template-columns: 68rpx minmax(0, 1fr);
    gap: 16rpx;
    padding: 20rpx 6rpx;
  }
}

.player-row .roster-avatar {
  background: #eef2f6;
  border: 0;
  color: #6b7280;
  font-size: 26rpx;
  height: 70rpx;
  width: 70rpx;
  margin-left: 4rpx;
}
@media (max-width: 360rpx) {
  .player-row .roster-avatar { height: 60rpx; width: 60rpx; font-size: 22rpx; }
}

.player-row.open-slot .roster-avatar {
  background: #fff;
  border: 3rpx dashed #e2a724;
  color: #e2a724;
}

.player-row-main { min-width: 0; }

.player-row-head {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  min-height: 48rpx;
}
@media (max-width: 360rpx) {
  .player-row-head { gap: 6rpx; }
}

.player-name-line {
  align-items: center;
  display: flex;
  flex: 1;
  gap: 10rpx;
  min-width: 0;
}

.player-row .roster-slot {
  color: #30343b;
  font-size: 32rpx;
  font-weight: 500;
  flex: 0 0 auto;
}
@media (max-width: 360rpx) {
  .player-row .roster-slot { font-size: 28rpx; }
}

.player-name {
  color: #30343b;
  font-size: 32rpx;
  font-weight: 500;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
@media (max-width: 360rpx) {
  .player-name { font-size: 28rpx; }
}

.player-slot-input,
.inline-name {
  background: transparent;
  border: 0;
  color: #30343b;
  flex: 1;
  font-size: 30rpx;
  height: 48rpx;
  line-height: 48rpx;
  min-width: 0;
  padding: 0;
}
.slot-save {
  background: #16744f;
  border-radius: 8rpx;
  color: #fff;
  flex: 0 0 auto;
  font-size: 22rpx;
  height: 44rpx;
  line-height: 42rpx;
  margin: 0;
  padding: 0 16rpx;
}
@media (max-width: 360rpx) {
  .slot-save { font-size: 20rpx; padding: 0 12rpx; }
}

.player-level-pill {
  color: #9ca3af;
  flex: 0 0 auto;
  font-size: 26rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 120rpx;
}
@media (max-width: 360rpx) {
  .player-level-pill { font-size: 22rpx; max-width: 96rpx; }
}
.player-level-pill.bound { color: #30343b; }

.player-row-meta {
  align-items: center;
  color: #a3a3a3;
  display: flex;
  flex-wrap: wrap;
  font-size: 24rpx;
  gap: 8rpx;
  margin-top: 4rpx;
  min-width: 0;
  overflow: hidden;
}
@media (max-width: 360rpx) {
  .player-row-meta { font-size: 21rpx; gap: 6rpx; }
}

.source-pill {
  background: #eeeeee;
  border-radius: 999rpx;
  color: #777;
  font-size: 20rpx;
  line-height: 30rpx;
  padding: 0 8rpx;
  flex: 0 0 auto;
}
@media (max-width: 360rpx) {
  .source-pill { font-size: 18rpx; line-height: 26rpx; }
}

.player-inline-edit {
  align-items: center;
  display: grid;
  gap: 10rpx;
  grid-template-columns: minmax(0, 1fr) 88rpx 150rpx 96rpx;
  margin-top: 12rpx;
}
@media (max-width: 360rpx) {
  .player-inline-edit {
    grid-template-columns: 1fr;
    gap: 8rpx;
  }
}

.player-row .roster-gender,
.player-row .roster-actions { grid-column: auto; }

.player-row .roster-gender .gender-choice,
.player-row .roster-actions button,
.player-row .roster-level-box {
  height: 48rpx;
  line-height: 46rpx;
}

.player-row-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}
.player-row-actions button {
  flex: 1 1 calc(33.33% - 6rpx);
  min-width: 0;
}
.player-row-actions.single button {
  flex: 1 1 calc(50% - 4rpx);
}
@media (max-width: 360rpx) {
  .player-row-actions button { flex-basis: 100%; }
}

.player-filter {
  align-items: center;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
}
.player-filter button {
  background: transparent;
  color: #16744f;
  font-size: 24rpx;
  margin: 0;
  padding: 0 8rpx;
  flex: 0 0 auto;
}

/* ---------- 对局卡片 ---------- */
.game-card {
  background: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 10rpx;
  margin-bottom: 14rpx;
  overflow: hidden;
  padding: 16rpx;
}
@media (max-width: 360rpx) {
  .game-card { padding: 12rpx; }
}

.game-card.done {
  background: #fff;
  border-color: #dbe3ea;
}

.round-line {
  align-items: flex-start;
  color: #2f6f58;
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  line-height: 1.35;
  flex-wrap: wrap;
}
.round-line text {
  min-width: 0;
  overflow-wrap: anywhere;
  word-break: break-all;
  flex: 1;
}
.round-line button {
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  color: #334155;
  flex: none;
  height: 52rpx;
  line-height: 50rpx;
  margin: 0;
  min-width: 132rpx;
  padding: 0 14rpx;
  width: auto;
  font-size: 22rpx;
}
@media (max-width: 360rpx) {
  .round-line { flex-direction: column; gap: 6rpx; }
  .round-line button { width: 100%; min-width: 0; }
}

/* ---------- 双方队伍 ---------- */
.teams {
  align-items: stretch;
  display: grid;
  gap: 10rpx;
  grid-template-columns: minmax(0, 1fr);
}
@media (min-width: 430rpx) {
  .teams {
    grid-template-columns: minmax(0, 1fr) 54rpx minmax(0, 1fr);
  }
}
@media (max-width: 360rpx) {
  .teams { gap: 8rpx; }
}

.team,
.team.right {
  align-items: flex-start;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  color: #111827;
  display: flex;
  gap: 10rpx;
  line-height: 1.35;
  min-height: 68rpx;
  padding: 12rpx;
  text-align: left;
  flex-wrap: wrap;
}
@media (max-width: 360rpx) {
  .team,
  .team.right {
    padding: 10rpx;
    min-height: 60rpx;
    gap: 6rpx;
  }
}

.team text:not(.team-label) {
  min-width: 0;
  overflow-wrap: anywhere;
  word-break: break-all;
  flex: 1;
}

.team-label {
  background: #2f6f58;
  border-radius: 6rpx;
  color: #fff;
  flex: 0 0 auto;
  height: 38rpx;
  line-height: 38rpx;
  text-align: center;
  width: 38rpx;
  font-size: 20rpx;
}
@media (max-width: 360rpx) {
  .team-label { height: 32rpx; line-height: 32rpx; width: 32rpx; font-size: 18rpx; }
}

.versus {
  background: #eef5f1;
  border: 1rpx solid #dbe3ea;
  border-radius: 999rpx;
  color: #2f6f58;
  font-size: 22rpx;
  height: 42rpx;
  line-height: 40rpx;
  text-align: center;
  width: 100%;
}

.rest {
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
  overflow-wrap: anywhere;
  word-break: break-all;
}
@media (max-width: 360rpx) {
  .rest { font-size: 21rpx; }
}

/* ---------- 记分板 ---------- */
.score-board {
  align-items: stretch;
  display: grid;
  gap: 10rpx;
  grid-template-columns: minmax(0, 1fr);
  margin-top: 14rpx;
}
@media (min-width: 430rpx) {
  .score-board {
    grid-template-columns: minmax(0, 1fr) 120rpx minmax(0, 1fr);
  }
}
@media (max-width: 360rpx) {
  .score-board { gap: 8rpx; }
}

.score-side {
  background: #f8fafc;
  border: 1rpx solid #dbe3ea;
  border-radius: 8rpx;
  display: grid;
  gap: 8rpx;
  grid-template-columns: 56rpx minmax(0, 1fr) 56rpx;
  padding: 8rpx;
}
@media (max-width: 360rpx) {
  .score-side {
    grid-template-columns: 48rpx minmax(0, 1fr) 48rpx;
    padding: 6rpx;
  }
}

.score-side button {
  background: #eef5f1;
  border: 1rpx solid #cfe1d8;
  border-radius: 6rpx;
  color: #2f6f58;
  height: 52rpx;
  line-height: 50rpx;
  margin: 0;
  padding: 0;
  width: 100%;
  font-size: 26rpx;
}
@media (max-width: 360rpx) {
  .score-side button { height: 44rpx; line-height: 42rpx; font-size: 22rpx; }
}

.score-side input {
  background: #fff;
  border: 1rpx solid #dbe3ea;
  border-radius: 6rpx;
  box-sizing: border-box;
  height: 52rpx;
  min-width: 0;
  padding: 0;
  text-align: center;
  width: 100%;
  font-size: 28rpx;
}
@media (max-width: 360rpx) {
  .score-side input { height: 44rpx; font-size: 24rpx; }
}

.finish-score {
  background: #2f6f58;
  border-radius: 8rpx;
  color: #fff;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  width: 100%;
  font-size: 26rpx;
}
@media (max-width: 360rpx) {
  .finish-score { height: 52rpx; line-height: 52rpx; font-size: 24rpx; }
}

/* ============================================================
   Radar Chart (CSS-only bar chart)
   ============================================================ */
.radar-section {
  margin-bottom: 18rpx;
}

.radar-section .section-subtitle {
  color: #64748b;
  display: block;
  font-size: 22rpx;
  margin-bottom: 14rpx;
}

.radar-grid {
  align-items: flex-end;
  display: flex;
  gap: 12rpx;
  justify-content: space-around;
  min-height: 200rpx;
  padding: 10rpx 0;
}

.radar-item {
  align-items: center;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.radar-bar-wrap {
  align-items: flex-end;
  background: #f1f5f9;
  border-radius: 6rpx 6rpx 0 0;
  display: flex;
  height: 140rpx;
  justify-content: center;
  width: 100%;
  overflow: hidden;
}

.radar-bar {
  background: linear-gradient(180deg, #16744f, #2d9f78);
  border-radius: 4rpx 4rpx 0 0;
  transition: height 0.3s ease;
  width: 100%;
  max-width: 56rpx;
  min-height: 4rpx;
}

.radar-label {
  color: #64748b;
  font-size: 22rpx;
  max-width: 100%;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.radar-value {
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
}

/* ============================================================
   近期趋势行
   ============================================================ */
.trend-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.trend-row {
  align-items: center;
  display: grid;
  gap: 10rpx;
  grid-template-columns: 120rpx minmax(0, 1fr) 180rpx;
  min-height: 48rpx;
}
@media (max-width: 360rpx) {
  .trend-row {
    grid-template-columns: 100rpx minmax(0, 1fr) 150rpx;
    gap: 8rpx;
  }
}

.trend-label {
  color: #475569;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.trend-track {
  background: #e2e8f0;
  border-radius: 999rpx;
  height: 18rpx;
  overflow: hidden;
  position: relative;
  width: 100%;
}

.trend-fill {
  background: #0f766e;
  border-radius: 999rpx;
  height: 18rpx;
  transition: width 0.3s ease;
}

.trend-stat {
  color: #64748b;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
}

/* ============================================================
   本周活跃度摘要
   ============================================================ */
.weekly-summary {
  align-items: center;
  background: #f0fdf4;
  border: 1rpx solid #bbf7d0;
  border-radius: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 14rpx;
}

.weekly-label {
  color: #166534;
  font-size: 24rpx;
  font-weight: 700;
}

.weekly-value {
  color: #15803d;
  font-size: 24rpx;
}

/* ============================================================
   meta-icon — 活动卡片图标
   ============================================================ */
.meta-icon {
  font-size: 20rpx;
  display: inline;
}

/* ============================================================
   quick-finish — 一键胜出按钮
   ============================================================ */
.quick-finish-row {
  display: flex;
  gap: 8rpx;
  justify-content: center;
  padding: 8rpx 0;
}

.quick-finish-btn {
  background: #eef5f1;
  border: 1rpx solid #c4ddd0;
  border-radius: 6rpx;
  color: #16744f;
  font-size: 22rpx;
  line-height: 1;
  padding: 10rpx 16rpx;
}

.quick-finish-btn:active {
  background: #d0e9de;
}

