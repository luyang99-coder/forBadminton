{
  "pages": [
    "pages/index/index",
    "pages/launch/index"
  ],
  "window": {
    "navigationBarTitleText": "羽毛球打转",
    "navigationBarBackgroundColor": "#16744F",
    "navigationBarTextStyle": "white",
    "backgroundColor": "#EEF3EF"
  },
  "subPackages": [
    {
      "root": "pages/stats",
      "name": "stats",
      "pages": [
        "index"
      ]
    },
    {
      "root": "pages/history",
